<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RegressionSuite">
    
    <listeners>
        <listener class-name="com.enterprise.banking.listeners.TestListener" />
        <listener class-name="com.enterprise.banking.listeners.RetryTransformer" />
    </listeners>
    
    <test name="UIAndAPIRegression">
        <classes>
            <class name="com.enterprise.banking.tests.RegistrationTest"/>
            <class name="com.enterprise.banking.tests.AccountOverviewTest"/>
