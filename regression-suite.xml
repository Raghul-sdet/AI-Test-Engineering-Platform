            <class name="com.enterprise.banking.tests.OpenAccountTest"/>
            <class name="com.enterprise.banking.tests.FindTransactionsTest"/>
            <class name="com.enterprise.banking.api.AccountApiTest"/>
        </classes>
    </test>
    
</suite>