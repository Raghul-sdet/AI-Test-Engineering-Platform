<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Browser Parallel Suite" parallel="tests" thread-count="3" verbose="1">

    <listeners>
        <listener class-name="com.enterprise.banking.listeners.TestListener"/>
    </listeners>

    <test name="Execution on Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.enterprise.banking.hybrid.tests.HybridE2ETest"/>
        </classes>
    </test>

    <test name="Execution on Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.enterprise.banking.hybrid.tests.HybridE2ETest"/>
        </classes>
    </test>

    <test name="Execution on Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.enterprise.banking.hybrid.tests.HybridE2ETest"/>
        </classes>
    </test>

</suite>