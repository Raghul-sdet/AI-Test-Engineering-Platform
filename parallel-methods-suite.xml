<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Methods Suite" parallel="methods" thread-count="5">
    <parameter name="browser" value="chrome"/>
    
    <listeners>
        <listener class-name="com.enterprise.banking.listeners.TestListener"/>
    </listeners>

    <test name="High Speed Method Execution">
        <classes>
            <class name="com.enterprise.banking.api.tests.GetCustomerDetailsTest"/>
        </classes>
    </test>
</suite>