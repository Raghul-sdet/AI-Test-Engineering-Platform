<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Classes Suite" parallel="classes" thread-count="4">
    <parameter name="browser" value="chrome"/>
    
    <listeners>
        <listener class-name="com.enterprise.banking.listeners.TestListener"/>
    </listeners>

    <test name="Module Tests">
        <classes>
            <class name="com.enterprise.banking.tests.LoginTest"/>
            <class name="com.enterprise.banking.tests.OpenAccountTest"/>
            <class name="com.enterprise.banking.tests.TransferFundsTest"/>
        </classes>
    </test>
</suite>